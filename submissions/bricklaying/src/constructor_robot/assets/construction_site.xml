<mujoco model="construction_site_mobile_manipulator">
  <option timestep="0.02" gravity="0 0 -9.81" integrator="RK4"/>
  <visual>
    <global azimuth="135" elevation="-25" offwidth="1280" offheight="720"/>
  </visual>
  <compiler angle="radian"/>
  <default>
    <geom friction="1.0 0.08 0.02" solref="0.01 1"/>
    <joint damping="1.5" armature="0.03"/>
  </default>
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.28 0.30 0.28" rgb2="0.34 0.36 0.34" width="512" height="512"/>
    <material name="floor_mat" texture="grid" texrepeat="8 8" reflectance="0.05"/>
    <material name="robot_mat" rgba="0.1 0.38 0.75 1"/>
    <material name="cargo_mat" rgba="0.85 0.55 0.18 1"/>
    <material name="human_zone_mat" rgba="0.85 0.18 0.12 0.22"/>
    <material name="arm_mat" rgba="0.94 0.72 0.24 1"/>
    <material name="rubber_mat" rgba="0.04 0.04 0.04 1"/>
    <material name="human_mat" rgba="0.15 0.5 0.85 1"/>
  </asset>

  <worldbody>
    <geom name="floor" type="plane" size="4 4 0.1" material="floor_mat"/>
    <light name="key" pos="0 -3 5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <camera name="site_overview" pos="0 -5 3.2" xyaxes="1 0 0 0 0.55 0.83"/>

    <body name="robot" pos="-2 -1.5 0.18">
      <freejoint name="robot_free"/>
      <geom name="mobile_base" type="box" size="0.34 0.24 0.14" material="robot_mat" mass="18"/>
      <geom name="left_track" type="box" pos="0 0.28 -0.04" size="0.35 0.055 0.07" material="rubber_mat" mass="2"/>
      <geom name="right_track" type="box" pos="0 -0.28 -0.04" size="0.35 0.055 0.07" material="rubber_mat" mass="2"/>
      <geom name="torso" type="box" pos="0 0 0.33" size="0.16 0.12 0.22" material="robot_mat" mass="8"/>
      <geom name="head_lidar" type="cylinder" pos="0 0 0.62" size="0.07 0.045" rgba="0.02 0.02 0.02 1" mass="1"/>
      <site name="robot_goal" pos="0 0 0.35" size="0.04" rgba="0.1 0.9 0.25 1"/>

      <body name="boom" pos="0.12 0 0.46">
        <joint name="shoulder" type="hinge" axis="0 1 0" range="-1.1 1.0" limited="true"/>
        <geom name="upper_arm" type="capsule" fromto="0 0 0 0.36 0 0.18" size="0.045" material="arm_mat" mass="3"/>
        <body name="forearm" pos="0.36 0 0.18">
          <joint name="elbow" type="hinge" axis="0 1 0" range="-1.8 0.5" limited="true"/>
          <geom name="lower_arm" type="capsule" fromto="0 0 0 0.32 0 -0.1" size="0.038" material="arm_mat" mass="2"/>
          <body name="wrist" pos="0.32 0 -0.1">
            <joint name="wrist" type="hinge" axis="0 1 0" range="-1.2 1.2" limited="true"/>
            <geom name="wrist_block" type="box" size="0.06 0.08 0.045" material="robot_mat" mass="1"/>
            <site name="grip_site" pos="0.11 0 0" size="0.035" rgba="0 1 0 1"/>
            <body name="left_finger" pos="0.1 0.06 0">
              <joint name="left_finger" type="slide" axis="0 -1 0" range="0 0.045" limited="true"/>
              <geom name="left_finger_pad" type="box" size="0.035 0.012 0.055" material="rubber_mat" mass="0.2"/>
            </body>
            <body name="right_finger" pos="0.1 -0.06 0">
              <joint name="right_finger" type="slide" axis="0 1 0" range="0 0.045" limited="true"/>
              <geom name="right_finger_pad" type="box" size="0.035 0.012 0.055" material="rubber_mat" mass="0.2"/>
            </body>
          </body>
        </body>
      </body>
    </body>

    <body name="cargo_block" pos="-2.15 -1.5 0.13">
      <freejoint name="cargo_free"/>
      <geom name="cargo_block_geom" type="box" size="0.16 0.11 0.09" material="cargo_mat" mass="4"/>
    </body>

    <body name="storage_marker" pos="-2 -1.5 0.02">
      <geom type="cylinder" size="0.22 0.02" rgba="0.25 0.65 0.95 0.45"/>
    </body>
    <body name="foundation_marker" pos="1.6 0.8 0.02">
      <geom type="box" size="0.75 0.35 0.02" rgba="0.45 0.28 0.16 0.45"/>
    </body>
    <body name="tool_bench_marker" pos="-1.8 1.4 0.1">
      <geom type="box" size="0.35 0.18 0.1" rgba="0.45 0.32 0.2 1"/>
    </body>
    <body name="inspection_marker" pos="2 -1.2 0.02">
      <geom type="cylinder" size="0.2 0.02" rgba="0.2 0.8 0.3 0.45"/>
    </body>

    <body name="human_zone" pos="0.45 0.55 0.01">
      <geom type="box" size="0.65 0.45 0.01" material="human_zone_mat" contype="0" conaffinity="0"/>
    </body>
    <body name="human_worker_1" pos="0.15 0.35 0.52">
      <geom name="worker_legs" type="capsule" fromto="0 -0.08 -0.42 0 -0.08 -0.08" size="0.035" material="human_mat" contype="0" conaffinity="0"/>
      <geom name="worker_legs_2" type="capsule" fromto="0 0.08 -0.42 0 0.08 -0.08" size="0.035" material="human_mat" contype="0" conaffinity="0"/>
      <geom name="worker_body" type="capsule" fromto="0 0 -0.08 0 0 0.24" size="0.08" material="human_mat" contype="0" conaffinity="0"/>
      <geom name="worker_head" type="sphere" pos="0 0 0.36" size="0.09" rgba="0.9 0.72 0.55 1" contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <actuator>
    <position name="shoulder_motor" joint="shoulder" kp="80" ctrlrange="-1.1 1.0"/>
    <position name="elbow_motor" joint="elbow" kp="70" ctrlrange="-1.8 0.5"/>
    <position name="wrist_motor" joint="wrist" kp="45" ctrlrange="-1.2 1.2"/>
    <position name="left_finger_motor" joint="left_finger" kp="30" ctrlrange="0 0.045"/>
    <position name="right_finger_motor" joint="right_finger" kp="30" ctrlrange="0 0.045"/>
  </actuator>
</mujoco>
